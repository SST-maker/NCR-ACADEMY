rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentRole() {
      return signedIn() && currentUserDoc().exists() ? currentUserDoc().data.role : 'student';
    }

    function isTrainer() {
      return currentRole() == 'trainer';
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isTrainer());
      allow create, update, delete: if signedIn() && isTrainer();
    }

    match /userStates/{userId} {
      allow read, write: if signedIn() && (request.auth.uid == userId || isTrainer());
    }

    match /tickets/{ticketId} {
      allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
      allow read: if signedIn() && (resource.data.authorId == request.auth.uid || isTrainer());
      allow update: if signedIn() && (resource.data.authorId == request.auth.uid || isTrainer());
      allow delete: if signedIn() && isTrainer();
    }

    match /trackingEvents/{eventId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isTrainer());
      allow update, delete: if false;
    }

    match /documents/{documentId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && isTrainer();
    }
  }
}
